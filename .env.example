# Portable host runtime. Copy to
# ${XDG_CONFIG_HOME:-~/.config}/agenvyl/agenvyl.env and replace the secrets.
AGENVYL_HOST=127.0.0.1
AGENVYL_PORT=8791
AGENVYL_CONNECTOR_URL=http://127.0.0.1:4310
AGENVYL_CONNECTOR_TOKEN=replace-with-at-least-32-random-characters

# PostgreSQL is the only production container and is published on loopback.
AGENVYL_POSTGRES_BIND_ADDRESS=127.0.0.1
AGENVYL_POSTGRES_PORT=5432
POSTGRES_PASSWORD=replace-me
AGENVYL_DATABASE_URL=postgres://agenvyl:replace-me@127.0.0.1:5432/agenvyl

# Defaults follow the XDG Base Directory layout. Optional absolute overrides:
# AGENVYL_CONNECTOR_CONFIG=/absolute/path/to/connector.yaml
# AGENVYL_WORKSPACE_ROOT=/absolute/path/to/workspaces
AGENVYL_WORKSPACE_MAX_FILE_BYTES=52428800
AGENVYL_RUN_CONCURRENCY=4
AGENVYL_RUN_TIMEOUT_MS=900000

# Harness-specific Connector settings. Keep credentials out of connector.yaml.
AGENVYL_CONNECTOR_HERMES_URL=http://127.0.0.1:8642
AGENVYL_CONNECTOR_HERMES_TOKEN=
AGENVYL_CONNECTOR_OPENCODE_URL=http://127.0.0.1:4096
AGENVYL_CONNECTOR_OPENCODE_USERNAME=opencode
AGENVYL_CONNECTOR_OPENCODE_PASSWORD=
AGENVYL_CONNECTOR_OPENCODE_CATALOG_DIRECTORY=
# AGENVYL_CONNECTOR_AGY_COMMAND=/absolute/path/to/agy
# Claude Code CLI is user-installed and is never included in portable bundles.
# AGENVYL_CONNECTOR_CLAUDE_COMMAND=/absolute/path/to/claude

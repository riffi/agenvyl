# Portable local runtime. Copy to .env and adjust only what your setup needs.
AGENVYL_BIND_ADDRESS=127.0.0.1
AGENVYL_PORT=8791
AGENVYL_WORKSPACE_PATH=./data/room-workspaces
POSTGRES_PASSWORD=agenvyl

# Connector is the only Core execution backend. Core fails fast unless URL and token are set.
# Generate one shared Core/Connector token, for example: openssl rand -hex 32
# Use 127.0.0.1 for a host Core; Compose needs an endpoint reachable from its container.
AGENVYL_CONNECTOR_URL=
AGENVYL_CONNECTOR_TOKEN=

# Set this to the absolute host workspace path when the harness runs outside Compose.
AGENVYL_WORKSPACE_AGENT_ROOT=/absolute/path/to/agenvyl/data/room-workspaces
AGENVYL_WORKSPACE_MAX_FILE_BYTES=52428800
AGENVYL_RUN_CONCURRENCY=4
# Maximum wall-clock execution time after the upstream run starts (default: 15 minutes).
AGENVYL_RUN_TIMEOUT_MS=900000

# Host-side Connector. Keep the token out of connector.yaml.
AGENVYL_CONNECTOR_CONFIG=./connector.yaml
AGENVYL_CONNECTOR_HERMES_URL=http://127.0.0.1:8642
AGENVYL_CONNECTOR_HERMES_TOKEN=
# Enable the opencode instance in connector.yaml and run `opencode serve` first.
AGENVYL_CONNECTOR_OPENCODE_URL=http://127.0.0.1:4096
AGENVYL_CONNECTOR_OPENCODE_USERNAME=opencode
AGENVYL_CONNECTOR_OPENCODE_PASSWORD=
AGENVYL_CONNECTOR_OPENCODE_CATALOG_DIRECTORY=

{
  "name": "agenvyl",
  "private": true,
  "version": "0.1.0",
  "description": "Room-first orchestration for multiple coding-agent harnesses",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riffi/agenvyl.git"
  },
  "bugs": {
    "url": "https://github.com/riffi/agenvyl/issues"
  },
  "homepage": "https://github.com/riffi/agenvyl#readme",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "workspaces": [
    "packages/contracts",
    "packages/connector-contract",
    "packages/runtime-config",
    "apps/connector"
  ],
  "scripts": {
    "dev": "npm run build:contracts && vite --config apps/frontend/vite.config.ts",
    "dev:server": "tsx watch apps/backend/src/index.ts",
    "dev:connector": "npm run build:contracts && tsx watch apps/connector/src/index.ts",
    "build:contracts": "tsc -p packages/contracts/tsconfig.json && tsc -p packages/connector-contract/tsconfig.json && tsc -p packages/runtime-config/tsconfig.json",
    "build": "npm run build:contracts && tsc -b --force && vite build --config apps/frontend/vite.config.ts && tsc -p tsconfig.server.json && cp apps/backend/src/infrastructure/database/migrations/*.sql apps/backend/dist/infrastructure/database/migrations/",
    "typecheck": "npm run build:contracts && tsc -b --pretty false",
    "lint:boundaries": "node scripts/check-frontend-boundaries.mjs && node scripts/check-backend-boundaries.mjs",
    "audit:oss": "node scripts/audit-oss-baseline.mjs",
    "test": "npm run build:contracts && vitest run --config vitest.unit.config.ts --exclude 'apps/backend/src/e2e/**' --exclude 'apps/connector/src/e2e/**' --exclude 'apps/backend/dist/**' --exclude 'apps/frontend/dist/**' --exclude 'server-dist/**' --exclude 'dist/**' --exclude 'packages/contracts/dist/**'",
    "test:e2e:hermes": "npm run build:contracts && vitest run apps/backend/src/e2e/hermes-connector.e2e.test.ts",
    "test:e2e:opencode": "npm run build:contracts && vitest run apps/backend/src/e2e/opencode-connector.e2e.test.ts",
    "smoke:hermes:live": "npm run build:contracts && vitest run apps/backend/src/e2e/hermes-live.smoke.test.ts",
    "smoke:opencode:live": "npm run build:contracts && vitest run apps/connector/src/e2e/opencode-live.smoke.test.ts",
    "smoke:antigravity:live": "npm run build:contracts && vitest run apps/backend/src/e2e/antigravity-live.smoke.test.ts",
    "bundle": "node scripts/build-runtime-bundle.mjs --arch all",
    "bundle:x64": "node scripts/build-runtime-bundle.mjs --arch x64",
    "bundle:arm64": "node scripts/build-runtime-bundle.mjs --arch arm64",
    "verify:bundle": "node scripts/verify-runtime-bundle.mjs",
    "start": "node apps/backend/dist/index.js",
    "start:connector": "node apps/connector/dist/index.js"
  },
  "dependencies": {
    "@agenvyl/contracts": "0.1.0",
    "@agenvyl/runtime-config": "0.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.3.0",
    "fastify": "^5.10.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/node": "^26.1.1",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.468.0",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.23.1",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
